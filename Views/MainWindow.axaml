<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:csharp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
        x:Class="csharp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="통신 로그 뷰어"
        Width="600" Height="450">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- 상단: 설정 및 연결 영역 -->
        <!-- Text="{Binding IpAddress}"를 통해 ViewModel의 값과 양방향 연결됩니다 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <TextBox Watermark="IP 주소" Text="{Binding IpAddress}" Width="150"/>
            <TextBox Watermark="포트" Text="{Binding Port}" Width="80"/>
            <Button Content="연결" Command="{Binding ConnectCommand}" HotKey="Enter"/>
            <Button Content="연결 해제" Command="{Binding DisconnectCommand}" Foreground="Red"/>
        </StackPanel>

        <!-- 중단: 로그 출력 영역 -->
        <!-- ItemsSource="{Binding LogMessages}"를 통해 리스트의 데이터가 화면에 출력됩니다 -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="3">
            <ListBox Background="#F0F0F0" ItemsSource="{Binding LogMessages}" />
        </Border>

        <!-- 하단: 메시지 전송 영역 -->
        <!-- Command="{Binding SendCommand}"를 통해 버튼 클릭 시 Send() 함수가 실행됩니다 -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,10,0,0">
            <TextBox Grid.Column="0" Watermark="보낼 메시지를 입력하세요..." 
                     Text="{Binding MessageToSend}" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Content="전송" Command="{Binding SendCommand}" Width="80"/>
        </Grid>
    </Grid>
</Window>